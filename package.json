{
    "name":  "wacrm",
    "version":  "0.8.0",
    "private":  true,
    "description":  "Self-hostable CRM for WhatsApp built on Next.js, Postgres, Drizzle, Better Auth, Alarik, and Soketi.",
    "license":  "MIT",
    "author":  "Arnas Donauskas",
    "homepage":  "https://github.com/ArnasDon/wacrm",
    "repository":  {
                       "type":  "git",
                       "url":  "git+https://github.com/ArnasDon/wacrm.git"
                   },
    "bugs":  {
                 "url":  "https://github.com/ArnasDon/wacrm/issues"
             },
    "keywords":  [
                     "crm",
                     "whatsapp",
                     "whatsapp-business-api",
                     "nextjs",
                     "postgres",
                     "automation",
                     "broadcast",
                     "self-hosted",
                     "template"
                 ],
    "engines":  {
                    "node":  "\u003e=20.0.0"
                },
    "scripts":  {
                    "dev":  "next dev",
                    "build":  "next build",
                    "start":  "next start",
                    "lint":  "eslint",
                    "typecheck":  "tsc --noEmit",
                    "infra:up":  "docker compose up -d postgres soketi alarik alarik-init",
                    "infra:down":  "docker compose down",
                    "db:generate":  "drizzle-kit generate",
                    "db:migrate":  "drizzle-kit migrate",
                    "db:studio":  "drizzle-kit studio",
                    "export:whaticket-db":  "node scripts/export-whaticket-db.mjs",
                    "import:whaticket":  "node scripts/import-whaticket.mjs",
                    "migrate:whaticket":  "node scripts/migrate-whaticket-progressive.mjs",
                    "format":  "prettier --write .",
                    "format:check":  "prettier --check .",
                    "test":  "vitest run",
                    "test:watch":  "vitest"
                },
    "dependencies":  {
                         "@aws-sdk/client-s3":  "^3.1090.0",
                         "@aws-sdk/s3-request-presigner":  "^3.1090.0",
                         "@base-ui/react":  "^1.6.0",
                         "@better-auth/drizzle-adapter":  "^1.6.23",
                         "@dagrejs/dagre":  "^3.0.0",
                         "@dnd-kit/core":  "^6.3.1",
                         "@dnd-kit/sortable":  "^10.0.0",
                         "@dnd-kit/utilities":  "^3.2.2",
                         "@xyflow/react":  "^12.11.0",
                         "better-auth":  "^1.6.23",
                         "class-variance-authority":  "^0.7.1",
                         "clsx":  "^2.1.1",
                         "date-fns":  "^4.4.0",
                         "drizzle-orm":  "^0.45.2",
                         "lucide-react":  "^1.22.0",
                         "next":  "16.2.6",
                         "next-intl":  "^4.13.1",
                         "opus-recorder":  "^8.0.5",
                         "pg":  "^8.22.0",
                         "pusher":  "^5.3.4",
                         "pusher-js":  "^8.5.0",
                         "react":  "19.2.4",
                         "react-dom":  "19.2.4",
                         "recharts":  "^3.8.1",
                         "shadcn":  "^4.11.0",
                         "sonner":  "^2.0.7",
                         "tailwind-merge":  "^3.6.0",
                         "tw-animate-css":  "^1.4.0",
                         "zod":  "^4.4.3"
                     },
    "devDependencies":  {
                            "@tailwindcss/postcss":  "^4",
                            "@types/node":  "^26",
                            "@types/pg":  "^8.20.0",
                            "@types/react":  "^19",
                            "@types/react-dom":  "^19",
                            "drizzle-kit":  "^0.31.10",
                            "eslint":  "^9",
                            "eslint-config-next":  "16.2.6",
                            "prettier":  "^3.9.1",
                            "prettier-plugin-tailwindcss":  "^0.8.0",
                            "tailwindcss":  "^4",
                            "typescript":  "^6",
                            "vitest":  "^4.1.9"
                        },
    "overrides":  {
                      "postcss":  "^8.5.10",
                      "ip-address":  "^10.1.1",
                      "fast-uri":  "^3.1.2",
                      "hono":  "^4.12.25",
                      "js-yaml":  "^4.2.0",
                      "@babel/core":  "^7.29.6"
                  }
}
